rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SECURE ASSESSMENT GATEWAY: SECURITY RULES CONFIGURATION
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admin_roles/$(request.auth.uid));
    }

    // --- COLLECTION RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Allow admins to see the user list for management
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /admin_roles/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Allow creation during sign-up OR by an existing admin
      allow create: if isOwner(adminId) || isAdmin(); 
      allow delete: if isAdmin(); 
      allow update: if false;
    }

    match /exams/{examId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /exams/{examId}/questions/{questionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{studentId}/results/{resultId} {
      allow get, list: if isOwner(studentId) || isAdmin();
      allow create: if isOwner(studentId);
      allow update: if isOwner(studentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /{path=**}/results/{resultId} {
      allow list: if isAdmin();
    }
  }
}